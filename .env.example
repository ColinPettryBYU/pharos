# Database (Supabase PostgreSQL)
PHAROS_DB_CONNECTION=Host=aws-0-us-east-1.pooler.supabase.com;Port=6543;Database=postgres;Username=postgres.xxxxx;Password=xxxxx;SSL Mode=Require;Trust Server Certificate=true

# Google OAuth
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx

# Social Media APIs (optional — for live API integration)
META_APP_ID=
META_APP_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
YOUTUBE_API_KEY=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Grading Accounts (passwords for seeded users)
ADMIN_PASSWORD=
DONOR_PASSWORD=
MFA_ADMIN_PASSWORD=

# Frontend
VITE_API_URL=https://pharos-api.azurewebsites.net/api
